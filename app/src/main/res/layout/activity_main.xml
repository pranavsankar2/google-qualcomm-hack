<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app"
    android:fitsSystemWindows="true">

    <!-- ── Header ─────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/text_app_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NeRF Scanner"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/text_backend_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NNAPI NPU"
                android:textSize="11sp"
                android:textColor="@color/brand_secondary"
                android:background="@drawable/bg_status_pill"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Body: Camera (left) | Stats dashboard (right) ─────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Camera preview fills left half -->
        <androidx.camera.view.PreviewView
            android:id="@+id/preview_view"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:scaleType="fillCenter"
            android:background="@color/black" />

        <!-- 1dp divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#DDDDDD" />

        <!-- Stats panel: right half -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- ── Scan status indicator ───────────────── -->
                <TextView
                    android:id="@+id/text_scan_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ READY"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.04" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="12dp" />

                <!-- ── Points Generated ────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="POINTS GENERATED"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.07" />

                <TextView
                    android:id="@+id/stat_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- ── Uncompressed Size ───────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UNCOMPRESSED"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.07" />

                <TextView
                    android:id="@+id/stat_uncompressed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- ── Neural Compressed ──────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEURAL COMPRESSED"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.07" />

                <TextView
                    android:id="@+id/stat_compressed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_secondary"
                    android:layout_marginBottom="12dp" />

                <!-- ── Compression Ratio ──────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPRESSION RATIO"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.07" />

                <TextView
                    android:id="@+id/stat_ratio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"
                    android:layout_marginBottom="12dp" />

                <!-- ── NPU Inference Time ─────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NPU INFERENCE"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.07" />

                <TextView
                    android:id="@+id/stat_inference"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="10dp" />

                <!-- ── Backend / model info ───────────────── -->
                <TextView
                    android:id="@+id/stat_backend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Backend: —"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/stat_models"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Models: —"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ── Control bar ───────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_scan"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="START SCAN"
                android:textSize="13sp"
                app:cornerRadius="26dp"
                app:backgroundTint="@color/brand_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_export"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="EXPORT TO CLOUD"
                android:textSize="12sp"
                app:cornerRadius="26dp"
                app:strokeColor="@color/brand_primary"
                android:enabled="false" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
